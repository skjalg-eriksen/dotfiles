#!/usr/bin/env bash
set -euo pipefail

# Create a temporary directory for ARM templates
TRIVY_TMP="$(mktemp -d /tmp/trivy-config.XXXXXX)"
trap 'rm -rf "$TRIVY_TMP"' EXIT

# Find the git repository root
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "Error: not inside a git repository" >&2
  exit 1
}

echo "Repository root: $REPO_ROOT"
echo "Temp directory:  $TRIVY_TMP"

# Find all .bicep files and build them to ARM JSON in the temp directory
BICEP_FILES="$(find "$REPO_ROOT" -type f -name '*.bicep')"

if [ -z "$BICEP_FILES" ]; then
  echo "No .bicep files found, skipping Bicep build step."
else
  echo "Building Bicep files to ARM templates..."
  while IFS= read -r bicep_file; do
    # Preserve directory structure in tmp
    rel_path="${bicep_file#"$REPO_ROOT"/}"
    out_dir="$TRIVY_TMP/$(dirname "$rel_path")"
    mkdir -p "$out_dir"

    arm_file="$out_dir/$(basename "${bicep_file%.bicep}.json")"
    echo "  $rel_path -> $arm_file"
    az bicep build --file "$bicep_file" --outfile "$arm_file"
  done <<< "$BICEP_FILES"
fi

# Copy IaC and Dockerfiles to the temp directory so everything is scanned together
echo "Copying IaC and Dockerfiles to temp directory..."
find "$REPO_ROOT" -type f \( \
  -name 'Dockerfile*' -o \
  -name '*.tf' -o \
  -name '*.yaml' -o \
  -name '*.yml' -o \
  -name '*.json' \
\) | while IFS= read -r f; do
  rel_path="${f#"$REPO_ROOT"/}"
  # Skip .git directory
  case "$rel_path" in .git/*) continue ;; esac
  out_dir="$TRIVY_TMP/$(dirname "$rel_path")"
  mkdir -p "$out_dir"
  cp "$f" "$out_dir/"
done

# Run Trivy config scan
echo ""
echo "Running Trivy config scan..."
echo "=============================="
trivy config \
  --severity CRITICAL,HIGH,MEDIUM \
  "$TRIVY_TMP"

# Cleanup is handled by the trap
echo ""
echo "Done. Temp files cleaned up."
